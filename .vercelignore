# Keep Vercel CLI uploads tight and free of any developer-machine secrets,
# logs, or local client data. Complements .gitignore.
node_modules
dist
.git
coverage
playwright-report
test-results
.vscode
.cursor
*.log
.env
.env.*
!.env.example

# Local encrypted stores must never be uploaded to Vercel
encryption.key
master.fallback
recovery.dat
admin-auth.dat
attendances.db
attendances.db-*
licences.db.enc
licence-config.json
photos/
userData/

# Build / installer outputs
build/output/
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
release-*.log

# Tests / scripts not needed in the static deploy.
# bundle-sqljs.mjs is REQUIRED by Vercel buildCommand — keep it.
tests/
scripts/
!scripts/bundle-sqljs.mjs

# Markdown docs (the static deploy is the app, not the docs)
*.md

# Electron-only files have no purpose in the static PWA deploy
main.js
preload.js
password-preload.js
updater.js
updateState.js
main/
infrastructure/
importers/
lib/
.cursorrules
.gitattributes
.eslintrc*
.prettierrc*
playwright.config.*
custody-note.code-workspace
launch.vbs
electron-builder.yml
