# Optional: GitHub token for release publish (create from https://github.com/settings/tokens)
# Copy to .env and add your token. .env is gitignored.
# GH_TOKEN=ghp_your_token_here

# Licence/backup server (for validation and managed AWS backup). Omit to use production.
# LICENCE_SERVER_BASE_URL=https://custodynote.com
# For local website: LICENCE_SERVER_BASE_URL=http://localhost:3000

# Apple notarisation credentials — required for npm run build:mac:signed.
# These are read by scripts/build-mac-signed.mjs from your shell environment.
# Use .env.local (also gitignored) so they persist across builds without being
# committed. Source them via:  set -a; source .env.local; set +a
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=ABCDE12345
