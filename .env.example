# Optional: GitHub classic PAT for releases and pushing workflow files.
# Scopes required: repo, workflow, read:org, gist
# https://github.com/settings/tokens/new?scopes=repo,workflow,read:org,gist
# Copy to .env.local (gitignored). Used by deploy and scripts/github-auth-with-workflow.mjs
# GH_TOKEN=github_pat_your_token_here

# Licence/backup server (for validation and managed AWS backup). Omit to use production.
# LICENCE_SERVER_BASE_URL=https://custodynote.com
# For local website: LICENCE_SERVER_BASE_URL=http://localhost:3000

# Apple notarisation credentials — required for npm run build:mac:signed.
# These are read by scripts/build-mac-signed.mjs from your shell environment.
# Use .env.local (also gitignored) so they persist across builds without being
# committed. Source them via:  set -a; source .env.local; set +a
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=ABCDE12345

# Optional: opt-in crash/error reporting (main + renderer).
# When UNSET, error reporting is a NO-OP — fatal errors are only logged locally
# (PII-redacted via lib/safeLog); nothing leaves the machine. To enable remote
# reporting set a DSN AND install the SDK:  npm i @sentry/electron
# All payloads are PII-redacted before send (see main/errorReporting.js).
# CUSTODYNOTE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
