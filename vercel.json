{
  "version": 2,
  "framework": null,
  "installCommand": "",
  "buildCommand": "echo Static deploy - no Electron build",
  "outputDirectory": ".",
  "routes": [
    { "src": "/sw.js", "headers": { "Cache-Control": "no-cache", "Service-Worker-Allowed": "/" } },
    { "src": "/data/(.*)", "headers": { "Cache-Control": "public, max-age=86400" } },
    { "src": "/(.*\\.js)", "headers": { "Cache-Control": "public, max-age=3600" } },
    { "src": "/(.*\\.css)", "headers": { "Cache-Control": "public, max-age=3600" } },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
