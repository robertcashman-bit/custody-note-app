{
  "version": 2,
  "framework": null,
  "installCommand": "npm install --omit=dev --no-audit --no-fund --ignore-scripts",
  "buildCommand": "node scripts/bundle-sqljs.mjs",
  "outputDirectory": ".",
  "trailingSlash": false,
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/browser-demo.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/index.html", "destination": "/index.html" },
    { "source": "/app.js", "destination": "/app.js" },
    { "source": "/browser-api.js", "destination": "/browser-api.js" },
    { "source": "/browser-demo.html", "destination": "/browser-demo.html" },
    { "source": "/vendor/sqljs/(.*)", "destination": "/vendor/sqljs/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=(), browsing-topics=(), bluetooth=(), serial=(), midi=(), hid=(), idle-detection=(), display-capture=(), publickey-credentials-get=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    },
    {
      "source": "/(index\\.html|app\\.js|browser-api\\.js|browser-demo\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/vendor/sqljs/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    }
  ]
}
